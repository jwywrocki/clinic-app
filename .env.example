# =============================================================================
# ENVIRONMENT VARIABLES FOR SPZOZ GOZ ŁOPUSZNO WEBSITE
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# =============================================================================
# SITE CONFIGURATION
# =============================================================================
# Base URL of your website
# Development: http://localhost:4000
# Production: https://your-domain.pl (replace with your actual domain)
NEXT_PUBLIC_SITE_URL=http://localhost:4000

# Environment setting (development/production)
NODE_ENV=development

# =============================================================================
# SUPABASE DATABASE CONFIGURATION
# =============================================================================
# Your Supabase project URL (found in Project Settings > API)
# Format: https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (found in Project Settings > API)
# This key is safe to use in client-side code
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key (found in Project Settings > API)
# This key has admin privileges - keep it secret and only use server-side
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# DATABASE CONNECTION CONFIGURATION
# =============================================================================
# Session Mode Pooler (for pg_dump - supports IPv4)
DB_HOST=aws-0-eu-central-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password

# Transaction Mode Pooler (for application connections)
DB_HOST_APP=aws-0-eu-central-1.pooler.supabase.com
DB_PORT_APP=6543
DB_USER_APP=postgres.your-project-id

# Direct connection (IPv6 - for future use if IPv6 support is added)
DB_HOST_DIRECT=db.your-project-id.supabase.co
DB_PORT_DIRECT=5432
DB_USER_DIRECT=postgres

# Legacy URL format (using transaction mode for app compatibility)
DATABASE_URL=postgresql://postgres.your-project-id:your-password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Session Mode URL (for pg_dump)
DATABASE_URL_SESSION=postgresql://postgres:your-password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Auth.js secret key (generate with: openssl rand -base64 32)
AUTH_SECRET=your-auth-secret-key

# Auth.js base URL (must match NEXT_PUBLIC_SITE_URL)
AUTH_URL=http://localhost:4000

# Bcrypt encryption settings
BCRYPT_SECRET_KEY=your-bcrypt-secret-key
BCRYPT_SALT_ROUNDS=10

# =============================================================================
# SCHEDULER CONFIGURATION
# =============================================================================
# Scheduler secret key for automatic tasks (backup, cleanup, etc.)
SCHEDULER_SECRET_KEY=your-scheduler-secret-key

# =============================================================================
# INSTRUKCJE KONFIGURACJI
# =============================================================================
# 1. Skopiuj ten plik do .env.local
# 2. Zastąp wszystkie wartości "your-*" prawdziwymi wartościami
# 3. Na produkcji koniecznie zmień NEXT_PUBLIC_SITE_URL na właściwą domenę
# 4. Nigdy nie commituj pliku .env.local do repozytorium
# 
# Przykład dla produkcji:
# NEXT_PUBLIC_SITE_URL=https://twoja-domena.pl
# NODE_ENV=production