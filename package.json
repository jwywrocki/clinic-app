{
    "name": "clinic-app",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "PORT=4000 next dev",
        "build": "next build",
        "start": "PORT=4000 next start",
        "lint": "next lint",
        "lint:fix": "next lint --fix",
        "type-check": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "pm2:start": "pm2 start ecosystem.config.cjs",
        "pm2:stop": "pm2 stop clinic-app",
        "pm2:restart": "pm2 restart clinic-app",
        "pm2:logs": "pm2 logs clinic-app",
        "deploy": "git pull && npm ci && npm run build && pm2 restart clinic-app"
    },
